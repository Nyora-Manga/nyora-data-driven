   "listUrl": "search",
   "capabilities": {
    "multipleTags": true,
    "tagsExclusion": true,
    "search": true,
    "searchWithFilters": true,
    "year": false,
    "authorSearch": true
   },
   "selectors": {
    "desc": ".summary .content, .summary .content ~ p",
    "state": ".detail .meta > p > strong:contains(Status) ~ a",
    "alt": ".detail h2",
    "tag": ".detail .meta > p > strong:contains(Genres) ~ a",
    "date": ".chapter-update",
    "chapter": "#chapter-list > li, #chapter-list-inner .chapter-list > li"
   }
  },
  "configComplex": {},
  "overriddenMethods": [
   "getListPage",
   "getDetails",
   "fetchAvailableTags",
   "getFilterOptions",
   "filterCapabilities"
